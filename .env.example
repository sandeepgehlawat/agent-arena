# Server Configuration
HOST=0.0.0.0
PORT=3460

# Environment (development/production)
ENVIRONMENT=production

# CORS - comma-separated list of allowed origins (* for all)
ALLOWED_ORIGINS=*

# XLayer RPC (mainnet: https://rpc.xlayer.tech, testnet: https://testrpc.xlayer.tech)
XLAYER_RPC=https://testrpc.xlayer.tech
XLAYER_CHAIN_ID=1952

# Contract addresses (update after deployment)
MOCK_IDENTITY_REGISTRY=
ARENA_REGISTRY=
MATCH_ESCROW=
MATCH_MANAGER=
TOURNAMENT_MANAGER=
LEADERBOARD_CONTRACT=

# USDC on XLayer
USDC_ADDRESS=0x74b7F16337b8972027F6196A17a631aC6dE26d22

# Identity Registry
IDENTITY_REGISTRY=

# Oracle private key (for result submission) - KEEP SECRET
ORACLE_PRIVATE_KEY=

# Platform wallet for receiving fees
PLATFORM_WALLET=

# OKX API (for x402 payments - optional)
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=
OKX_PROJECT_ID=

# Logging level
RUST_LOG=agent_arena_backend=info,tower_http=info
