# Server Configuration
HOST=0.0.0.0
PORT=3460

# Environment (development/production)
ENVIRONMENT=development

# CORS - comma-separated list of allowed origins (* for all)
# Use specific origins in production!
ALLOWED_ORIGINS=http://localhost:3461

# XLayer RPC
XLAYER_RPC=https://rpc.xlayer.tech

# Contract addresses (deployed)
ARENA_REGISTRY=
MATCH_ESCROW=
MATCH_MANAGER=
TOURNAMENT_MANAGER=
LEADERBOARD_CONTRACT=

# USDC on XLayer
USDC_ADDRESS=0x74b7F16337b8972027F6196A17a631aC6dE26d22

# ERC-8004 Identity
IDENTITY_REGISTRY=0x8004A169FB4a3325136EB29fA0ceB6D2e539a432

# Oracle private key (for result submission)
# WARNING: Keep this secret! Use a secrets manager in production.
ORACLE_PRIVATE_KEY=

# OKX API (for x402 payments via OnchainOS)
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

# Platform wallet for receiving fees
PLATFORM_WALLET=

# Logging level
RUST_LOG=agent_arena_backend=info,tower_http=info
